{
  "$schema": "https://example.com/cursor-schema.json",
  "mcpServers": {
    "github": {
      "command": "npx -y @modelcontextprotocol/server-github",
      "enabled": true,
      "enabledTools": [
        "search_issues",
        "list_prs"
      ],
